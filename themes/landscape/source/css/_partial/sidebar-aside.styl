// YJ Blog 定制样式优化 2026
#sidebar
  @media mq-normal
    column(sidebar-column)

.widget-wrap
  margin: spacing-lg 0

.widget-title
  font-size: 0.9em
  font-weight: 600
  color: var(--yj-text-heading)
  text-transform: none
  letter-spacing: 0
  margin-bottom: spacing-sm
  padding-bottom: spacing-xs
  border-bottom: 2px solid var(--yj-main-color)

.widget
  color: var(--yj-text-body)
  text-shadow: none
  background: var(--yj-surface-elevated)
  box-shadow: var(--yj-shadow-card)
  border: 1px solid var(--yj-border-default)
  border-radius: radius-md
  padding: spacing-md
  a
    color: var(--yj-text-link)
    text-decoration: none
    transition: color 0.2s ease
    &:hover
      color: var(--yj-text-link-hover)
      text-decoration: none
  ul, ol, dl
    ul, ol, dl
      margin-left: 15px
      list-style: disc

[data-theme="dark"]
  .widget
    background: var(--color-surface-elevated)
    border-color: var(--color-border-default)
    color: var(--color-text-primary)
    a
      color: var(--color-text-link)
      &:hover
        color: var(--color-text-link-hover)

  .widget-title
    color: var(--yj-text-heading)
    border-bottom-color: var(--yj-main-color)

  .tagcloud a
    background: var(--yj-main-color-subtle)
    color: var(--yj-main-color)
    &:hover
      background: var(--yj-main-color)
      color: var(--yj-brand-primary-text)

  .widget.recent_posts li
    border-bottom-color: var(--color-border-default)
    a
      color: var(--color-text-primary)
      &:hover
        color: var(--color-text-link)
