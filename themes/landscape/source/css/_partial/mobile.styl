@media mq-mobile
  #mobile-nav
    position: absolute
    top: 0
    left: 0
    width: mobile-nav-width
    height: 100%
    background: color-mobile-nav-background
    border-right: 1px solid rgba(255, 255, 255, 0.1)

@media mq-mobile
  .mobile-nav-link
    display: block
    color: rgba(255, 255, 255, 0.8)
    text-decoration: none
    padding: 15px 20px
    font-weight: 400
    min-height: 44px
    line-height: 44px
    &:hover
      color: #fff
      background: rgba(255, 255, 255, 0.1)

[data-theme="dark"]
  #mobile-nav
    background: var(--color-dark-300)
  .mobile-nav-link
    color: var(--color-brand-primary-text)
    &:hover
      color: #fff
      background: rgba(255, 255, 255, 0.1)
