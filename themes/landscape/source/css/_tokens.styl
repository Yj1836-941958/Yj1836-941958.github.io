  --color-accent-primary-hover: var(--yj-main-color-dark)
  --color-brand-primary: var(--yj-brand-primary)
  --color-brand-primary-text: var(--yj-brand-primary-text)
  --color-code-inline-bg: var(--yj-code-inline-bg)
  --color-code-inline-text: var(--yj-code-inline-text)
  --color-code-block-bg: var(--yj-code-bg)
  --color-blockquote-bg: var(--yj-blockquote-bg)
  --color-blockquote-border: var(--yj-blockquote-border)
  --color-blockquote-text: var(--yj-blockquote-text)
  --color-table-header-bg: var(--yj-table-header-bg)
  --color-table-stripe-bg: var(--yj-table-stripe-bg)
  --color-table-hover-bg: var(--yj-table-hover-bg)
  --color-bold-text: var(--yj-bold-text)
  --img-brightness: var(--yj-img-brightness)
  --cjk-text-indent: var(--yj-cjk-text-indent)
  --theme-transition: var(--yj-theme-transition)

