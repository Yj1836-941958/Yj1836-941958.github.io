  --yj-table-hover-bg: rgba(123, 163, 196, 0.06)
  --yj-brand-primary: #1e2a3a
  --yj-brand-primary-text: #f3f4f6
  --yj-bold-text: #7ba3c4
  --yj-img-brightness: 0.9
  --yj-cjk-text-indent: 2em
  --yj-theme-transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease
  --color-text-primary: var(--yj-text-body)
  --color-text-secondary: var(--yj-text-muted)
  --color-text-tertiary: #6b7280
  --color-text-heading: var(--yj-text-heading)
